{
  "name": "drizzle",
  "version": "1.0.0",
  "description": "Drizzle ORM adapter for Klyron",
  "orm": {
    "name": "Drizzle ORM",
    "detection_file": "package.json,drizzle.config.*",
    "detection_key": "drizzle-orm",
    "supported_versions": ["0.38", "0.40"],
    "default_version": "0.40",
    "kind": "ORM",
    "language": "TypeScript",
    "database_support": ["PostgreSQL", "MySQL", "SQLite", "D1", "Neon", "PlanetScale"]
  }
}
