{
  "name": "typeorm",
  "version": "1.0.0",
  "description": "TypeORM adapter for Klyron",
  "orm": {
    "name": "TypeORM",
    "detection_file": "package.json,typeorm.config.*,data-source.*",
    "detection_key": "typeorm",
    "supported_versions": ["0.3"],
    "default_version": "0.3",
    "kind": "ORM",
    "language": "TypeScript",
    "database_support": ["PostgreSQL", "MySQL", "SQLite", "SQL Server", "MongoDB"]
  }
}
