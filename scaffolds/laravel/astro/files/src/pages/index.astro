---
const health = await fetch('http://localhost:8000/api/health')
  .then(r => r.json())
  .catch(() => ({ status: 'unreachable' }))
---

<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>{{ name }}</title></head>
<body class="flex min-h-screen flex-col items-center justify-center bg-gray-100">
  <h1 class="text-4xl font-bold sm:text-6xl">{{ name }}</h1>
  <p class="mt-4 text-lg text-gray-600">{{ description }}</p>
  <div class="mt-4 text-sm text-gray-500">API: {health.status}</div>
</body>
</html>
