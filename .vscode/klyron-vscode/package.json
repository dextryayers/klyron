{
  "name": "klyron",
  "displayName": "Klyron",
  "description": "Klyron language support - Universal Polyglot Runtime",
  "version": "0.1.0",
  "publisher": "klyron",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Debuggers"
  ],
  "keywords": ["klyron", "javascript", "typescript", "php", "python", "ruby", "polyglot"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "klyron.run",
        "title": "Klyron: Run File"
      },
      {
        "command": "klyron.test",
        "title": "Klyron: Run Tests"
      },
      {
        "command": "klyron.build",
        "title": "Klyron: Build Project"
      },
      {
        "command": "klyron.dev",
        "title": "Klyron: Start Dev Server"
      },
      {
        "command": "klyron.format",
        "title": "Klyron: Format File"
      },
      {
        "command": "klyron.lint",
        "title": "Klyron: Lint File"
      }
    ],
    "keybindings": [
      {
        "command": "klyron.run",
        "key": "ctrl+alt+k"
      },
      {
        "command": "klyron.test",
        "key": "ctrl+alt+t"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "klyron.run",
          "group": "klyron"
        },
        {
          "command": "klyron.test",
          "group": "klyron"
        }
      ],
      "explorer/context": [
        {
          "command": "klyron.run",
          "group": "klyron"
        }
      ]
    },
    "configuration": {
      "title": "Klyron",
      "properties": {
        "klyron.binaryPath": {
          "type": "string",
          "default": "klyron",
          "description": "Path to the Klyron binary"
        },
        "klyron.autoStartDev": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start dev server on project open"
        },
        "klyron.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Format files on save using Klyron"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
