# Klyron Configuration
KLYRON_LOG_LEVEL=info          # debug | info | warn | error
KLYRON_CACHE_DIR=~/.klyron/cache
KLYRON_REGISTRY_DEFAULT=https://registry.npmjs.org
KLYRON_REGISTRY_MIRROR=
KLYRON_TELEMETRY=false
KLYRON_ENGINE=boa              # boa | v8 | quickjs | jsc | auto
KLYRON_ENGINE_MEMORY_LIMIT=512 # MB
KLYRON_SANDBOX=none            # none | basic | strict | maximum
KLYRON_HTTP_PORT=3000
KLYRON_HTTP_HOST=0.0.0.0
KLYRON_DEPLOY_TARGET=vercel
KLYRON_DOCKER_REGISTRY=docker.io
KLYRON_PLUGIN_DIR=~/.klyron/plugins
KLYRON_NODE_COMPAT=true
KLYRON_TS_CHECK=true
KLYRON_WATCH=true
KLYRON_AI_MODEL=gpt-4
KLYRON_AI_KEY=
KLYRON_COLORS=true
KLYRON_EDITOR=code
